{
  "manifest_version": 3,
  "name": "Better Google AI Studio",
  "version": "1.1.0",
  "description": "Enhances Google AI Studio with conversation branching capabilities.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://aistudio.google.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["utils/logger.js", "libs/d3.v7.min.js", "libs/transformers.min.js", "embeddings.js", "network.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": ["https://aistudio.google.com/*"],
      "js": ["utils/logger.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["libs/*"],
      "matches": ["https://aistudio.google.com/*"]
    }
  ]
}
